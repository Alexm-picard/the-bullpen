#!/usr/bin/env bash
# Pre-commit hook for The Bullpen.
#
# Enforces, for EVERY staged contracts/feature_pipeline*.json (L7: the post /
# battedball / lgbm variants were uncovered until 2026-06-11; only the pitch-pre
# file was checked):
#   - schema_hash matches actual file content
#   - pipeline_version was bumped when the schema changed
#
# Install: ./.githooks/install.sh   (sets git config core.hooksPath .githooks)

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

check_contract() {
  local rel="$1"
  local fp="${REPO_ROOT}/${rel}"

  if [[ ! -f "$fp" ]]; then
    echo "PRE-COMMIT FAIL: ${rel} is staged but doesn't exist on disk." >&2
    return 1
  fi

  # Recompute the schema hash via the canonical hasher - the single source of truth,
  # shared with the JVM registry parity contract (FeatureSchemaHasher / CanonicalJson).
  # It is stdlib-only, so it runs under the hook's bare python3; its algorithm is the one
  # this hook used to inline, proven byte-identical across every contracts/feature_pipeline*.json
  # before the dedup (hashes the content with the top-level schema_hash field zeroed out).
  local computed declared
  computed=$(PYTHONPATH="${REPO_ROOT}/training/src" python3 -c \
    "import sys; from bullpen_training.registry_client.feature_hasher import compute; print(compute(sys.argv[1]))" \
    "$fp")
  declared=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('schema_hash',''))" "$fp")

  if [[ "$computed" != "$declared" ]]; then
    echo "" >&2
    echo "PRE-COMMIT FAIL: ${rel} schema_hash is stale." >&2
    echo "  declared: $declared" >&2
    echo "  computed: $computed" >&2
    echo "" >&2
    echo "Set the schema_hash field to the computed value above:" >&2
    echo "  $computed" >&2
    echo "" >&2
    echo "  (or run: PYTHONPATH=\"${REPO_ROOT}/training/src\" python3 -c \"import json; from bullpen_training.registry_client.feature_hasher import compute; d=json.load(open('$fp')); d['schema_hash']=compute('$fp'); json.dump(d,open('$fp','w'),indent=2)\")" >&2
    echo "" >&2
    echo "Then bump pipeline_version and re-stage." >&2
    return 1
  fi

  # Check pipeline_version was bumped if the schema itself changed
  # (Compare staged version against HEAD's version)
  local new_version old_version staged_diff
  new_version=$(python3 -c "import json; print(json.load(open('$fp')).get('pipeline_version','MISSING'))" 2>/dev/null)
  old_version=$(git show "HEAD:${rel}" 2>/dev/null | python3 -c "import json,sys; print(json.load(sys.stdin).get('pipeline_version','MISSING'))" 2>/dev/null || echo "NONE")

  if [[ "$old_version" != "NONE" && "$new_version" == "$old_version" ]]; then
    staged_diff=$(git diff --cached -- "$fp" | grep -E '^[+-]' | grep -vE '^\+\+\+|^---|^[+-]\s*"schema_hash"' | wc -l | tr -d ' ')
    if [[ "${staged_diff:-0}" -gt 0 ]]; then
      echo "" >&2
      echo "PRE-COMMIT FAIL: ${rel} changed but pipeline_version did not bump." >&2
      echo "  pipeline_version: $old_version (still)" >&2
      echo "" >&2
      echo "Bump pipeline_version (semver: MAJOR for breaking changes, MINOR for additions, PATCH for fixes)" >&2
      echo "and re-stage." >&2
      return 1
    fi
  fi

  echo "pre-commit: ${rel} OK (schema_hash=$declared, pipeline_version=$new_version)"
  return 0
}

STAGED_CONTRACTS=$(git diff --cached --name-only | grep -E '^contracts/feature_pipeline[^/]*\.json$' || true)
if [[ -z "$STAGED_CONTRACTS" ]]; then
  exit 0
fi

STATUS=0
while IFS= read -r rel; do
  check_contract "$rel" || STATUS=1
done <<< "$STAGED_CONTRACTS"

exit $STATUS
