# /etc/default/bullpen - systemd EnvironmentFile for the app units (M2 template).
#
# Loaded by bullpen-api.service, bullpen-worker.service, bullpen-retrain.service,
# bullpen-stale-claim-reaper.service, and the backup units via `EnvironmentFile=-/etc/default/bullpen`
# (the leading `-` makes it optional, so a fresh box still boots - but the api refuses to start
# without THEBULLPEN_ADMIN_BASIC_AUTH and the worker crash-loops without BULLPEN_CLICKHOUSE_ENABLED).
#
# This committed .example documents every variable the box needs so a clean `git clone` + bootstrap
# can reconstruct the env. Copy to /etc/default/bullpen and fill in real values. The real file is
# gitignored (secrets). Docker-compose stateful-service secrets live in infra/.env (see
# infra/.env.example), NOT here. Some units also read a secrets-only file /etc/bullpen/secrets.env;
# populate it with the same secret values (THEBULLPEN_ADMIN_BASIC_AUTH, BULLPEN_CLICKHOUSE_PASSWORD,
# S3_*, RCLONE/offsite) if those units are enabled.

# --- Core app (REQUIRED) ---------------------------------------------------------------------
# HTTP-Basic credential for /v1/admin/** AND the ADMIN-gated /actuator/{prometheus,metrics} (M5),
# in the form "user:password". The api refuses to boot if unset. Both halves (raw user + raw
# password) seed infra/prometheus/secrets/metrics_user + metrics_pw via
# infra/prometheus/mk-metrics-secrets.sh so Prometheus can scrape - any username works.
THEBULLPEN_ADMIN_BASIC_AUTH=admin:REPLACE_WITH_STRONG_PASSWORD

# Live model-registry SQLite path. The app appends ?foreign_keys=true&busy_timeout=5000 itself (M4);
# set only the path here.
BULLPEN_REGISTRY_DB=/opt/bullpen/data/registry.sqlite

# --- ClickHouse (REQUIRED for the analytical paths) ------------------------------------------
BULLPEN_CLICKHOUSE_ENABLED=true
BULLPEN_CLICKHOUSE_URL=jdbc:ch:http://localhost:8123/default
BULLPEN_CLICKHOUSE_USER=default
# Same rotated secret the ClickHouse container reads (infra/.env BULLPEN_CLICKHOUSE_PASSWORD).
BULLPEN_CLICKHOUSE_PASSWORD=REPLACE_WITH_ROTATED_CLICKHOUSE_SECRET

# --- Live ingest (decision [157], ingest-only per [154]) -------------------------------------
BULLPEN_INGEST_LIVE_ENABLED=true

# --- S3-compatible object storage (ADR-0007): prod = Cloudflare R2 --------------------------
S3_ENDPOINT_URL=https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=REPLACE
S3_SECRET_ACCESS_KEY=REPLACE
S3_BUCKET=bullpen-prod

# --- Notifications + health pings ------------------------------------------------------------
# App-side Discord (drift/ops). Blank = log-only.
DISCORD_WEBHOOK_URL=
# Backup scripts' Discord webhook + Healthchecks.io ping URLs.
BULLPEN_DISCORD_WEBHOOK=
BULLPEN_HC_PING_URL=
BULLPEN_OFFSITE_HC_PING_URL=

# --- Offsite backup leg (ADR-0007 rev 2026-06-11) -------------------------------------------
BULLPEN_OFFSITE_REMOTE=r2:bullpen-prod/backups
# rclone runs as root from the timer, so the config path must be explicit (it lives under the dev
# user's home).
RCLONE_CONFIG=/home/REPLACE_USER/.config/rclone/rclone.conf
RCLONE_BIN=/usr/bin/rclone

# --- Error tracking (ADR-0008): blank disables the Sentry SDK --------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_RELEASE=

# --- Optional ---------------------------------------------------------------------------------
# BULLPEN_PORT=8080
