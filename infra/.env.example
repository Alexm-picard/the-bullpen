# infra/.env - environment for `docker compose -f infra/docker-compose.yml`.
# Copy to infra/.env (gitignored) and fill in. Load it with `--env-file infra/.env`, or run
# compose from the infra/ directory so Compose picks it up automatically.
#
# Since the CH-password rotation (decision [161]), the ClickHouse container is FAIL-CLOSED: it
# refuses to start without BULLPEN_CLICKHOUSE_PASSWORD (no `thebullpen` default anymore). This file
# is the durable source for that secret on the box (and locally).

# The ClickHouse secret. docker-compose seeds the container's user with this, and the app + backup
# tooling authenticate with it. Use the rotated strong secret in prod; never commit the real value.
BULLPEN_CLICKHOUSE_PASSWORD=

# Path B (dedicated SQL-managed app user). The app + backup/drill tooling authenticate as this user.
# Leave `default` until the `bullpen` user has been CREATEd (via access_management) and granted;
# set to `bullpen` at the cutover so the secret above belongs to a SQL-managed (ALTER-able) user.
# BULLPEN_CLICKHOUSE_USER=default

# Grafana is FAIL-CLOSED like ClickHouse: compose refuses to start without this (the old
# admin/admin fallback is gone). Set a real one everywhere.
GRAFANA_ADMIN_PASSWORD=

# Required when the errortracking profile is up (GlitchTip refuses to start without it):
# GLITCHTIP_SECRET_KEY=        # e.g. openssl rand -hex 32

# GlitchTip's internal Postgres credentials. The defaults preserve the already-initialized
# volume (postgres/postgres); POSTGRES_PASSWORD only applies on FIRST init of glitchtip-pg-data,
# so rotating here does nothing to an existing DB (rotate inside postgres first).
# GLITCHTIP_DB_USER=postgres
# GLITCHTIP_DB_PASSWORD=postgres

# M3: per-service memory caps (defaults shown). The ~12 GiB WSL2 pool is shared with the JVM app,
# so dropping ClickHouse is the main lever. Override any of these here.
# BULLPEN_CLICKHOUSE_MEM=4g    # default 8g
# BULLPEN_PROMETHEUS_MEM=768m
# BULLPEN_GRAFANA_MEM=512m
# BULLPEN_ALERTMANAGER_MEM=256m
# BULLPEN_NODE_EXPORTER_MEM=128m
# BULLPEN_GLITCHTIP_WEB_MEM=768m
# BULLPEN_GLITCHTIP_WORKER_MEM=768m
# BULLPEN_GLITCHTIP_PG_MEM=512m
# BULLPEN_GLITCHTIP_REDIS_MEM=256m

# M3: which profiles infra/check-stack.sh expects to be running (default: "monitoring errortracking").
# BULLPEN_STACK_PROFILES=monitoring errortracking
