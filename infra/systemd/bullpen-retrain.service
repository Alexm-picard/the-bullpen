[Unit]
Description=The Bullpen — single-shot retrain worker (claim → train → register → mark)
Documentation=https://github.com/Alexm-picard/the-bullpen/blob/main/docs/plans/phase-3-ml-wrapper/3d-retraining/3d.3-python-retrain-job.md
After=network-online.target bullpen-api.service
Wants=network-online.target
# Hard-depends on the api: the worker hits /v1/admin/retrain/claim + register.
# If the api is down the worker exits clean (claim raises BullpenAdminError →
# exit code 2, no row touched), so this "after" is correctness-not-required.

[Service]
Type=oneshot
User=bullpen
Group=bullpen
# TWO box prerequisites before this unit's timer is re-armed (M2-B; install.sh installs it
# DISABLED until these are met, so a reinstall cannot flip it to "enabled + failing"):
#   1. uv provisioned at /usr/local/bin/uv (owner decision 2026-07-03: install/symlink uv
#      there so the ExecStart below resolves - the box previously had no uv at that path).
#   2. The training PROJECT present at WorkingDirectory below. deploy.sh stages only app.jar
#      to /opt/bullpen, NOT training/, so /opt/bullpen/training must be provisioned separately
#      (checkout / clone / a deploy step) for `uv run` to find pyproject.toml + src.
# Re-arm after both: sudo systemctl enable --now bullpen-retrain.timer
WorkingDirectory=/opt/bullpen/training

# secrets.env carries BULLPEN_ADMIN_USER + BULLPEN_ADMIN_PASSWORD that match
# the THEBULLPEN_ADMIN_BASIC_AUTH credentials the api was started with.
EnvironmentFile=-/etc/default/bullpen
EnvironmentFile=-/etc/bullpen/secrets.env
Environment=BULLPEN_ADMIN_BASE_URL=http://127.0.0.1:8080

# The proven working env block (BOX HAND-OFF #1, decision [178] - the 15-attempt
# ledger burned at least one run on each missing variable; see the retrain-ceremony
# runbook Step 2 for the annotated list). Non-secrets are set here; the SECRETS
# (BULLPEN_ADMIN_USER / BULLPEN_ADMIN_PASSWORD derived from THEBULLPEN_ADMIN_BASIC_AUTH,
# and CH_ADMIN_PASSWORD for the loader's per-chunk SYSTEM JEMALLOC PURGE - without it
# the purge warn+no-ops and the cross-year retention ratchet returns) MUST live in
# /etc/bullpen/secrets.env above. Re-arm checklist before `systemctl enable --now
# bullpen-retrain.timer`: uv at /usr/local/bin/uv, /opt/bullpen/training provisioned,
# secrets.env carries all three secrets, and the two dirs below exist with
# alepic-writable/bullpen-readable perms.
Environment=BULLPEN_RETRAIN_ARTIFACT_DIR=/opt/bullpen/retrain-artifacts
Environment=BULLPEN_FEATURE_PIPELINE_PATH=/opt/bullpen/contracts/feature_pipeline_battedball.json
# Optional, advisory (120s timeout then proceed): drain background merges first.
Environment=BULLPEN_LOADER_MERGE_QUIET=1

# uv resolves the project venv from training/pyproject.toml; the worker module
# entry point is python -m bullpen_training.retraining.run.
ExecStart=/usr/local/bin/uv run python -m bullpen_training.retraining.run

# Worker exit codes (see run.py docstring):
#   0 — succeeded OR queue empty (nothing to do)
#   1 — training pipeline raised; row marked FAILED
#   2 — admin-API call failed; row may be RUNNING-stuck (reaper recovers)
# All three are "expected" from systemd's perspective — don't restart on failure.
SuccessExitStatus=0 1 2

# Don't auto-restart — the .timer fires this hourly; restarting on failure
# would just thrash if the api is wedged. Operator inspects logs instead.
Restart=no

StandardOutput=journal
StandardError=journal
SyslogIdentifier=bullpen-retrain

# Soft hardening (matches bullpen-api).
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/opt/bullpen
