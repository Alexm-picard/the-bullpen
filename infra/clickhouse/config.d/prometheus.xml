<!-- M1 task 6: ClickHouse's NATIVE Prometheus endpoint on :9363. Rationale: the api stays UP
     when ClickHouse dies (Hikari initializationFailTimeout(-1)), so ApiDown never fires for a
     dead CH - the ClickHouseDown rule needs a scrape target that IS ClickHouse. Mounted at
     /etc/clickhouse-server/config.d/prometheus.xml (see infra/docker-compose.yml); the container
     recreate that applies this happens at the M2 window, not on merge. -->
<clickhouse>
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
    </prometheus>
</clickhouse>
