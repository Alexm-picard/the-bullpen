# OS / editor
.DS_Store
.idea/
.vscode/
*.iml
*.swp

# Secrets — never commit
.env
.env.*
!.env.example

# --- Java / Gradle ---
backend/.gradle/
backend/build/
backend/out/
backend/bin/
backend/data/                  # local SQLite registry; the schema lives in src/main/resources/db/migration
backend/HELP.md

# --- Python / uv ---
training/.venv/
training/.python-version
training/__pycache__/
training/**/__pycache__/
training/.pytest_cache/
training/.ruff_cache/
training/.coverage
training/htmlcov/
training/build/
training/dist/
