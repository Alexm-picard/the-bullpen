# OS / editor
.DS_Store
.idea/
.vscode/
*.iml
*.swp

# Tool scratch — Playwright MCP console logs + QA screenshots (local only)
.playwright-mcp/

# Secrets — never commit
.env
.env.*
!.env.example

# --- Java / Gradle ---
backend/.gradle/
backend/build/
backend/out/
backend/bin/
# Ignore the local SQLite registry contents (schema lives in src/main/resources/db/migration), but
# KEEP the directory via .gitkeep so the jdbc:sqlite datasource has a parent dir to create into on a
# fresh checkout (untracking registry.sqlite without this broke app boot in CI).
backend/data/*
!backend/data/.gitkeep
backend/HELP.md

# --- Python / uv ---
training/.venv/
training/.python-version
__pycache__/
*.pyc
training/.pytest_cache/
training/.ruff_cache/
training/.coverage
training/htmlcov/
training/build/
training/dist/
training/*.egg-info/

# Promotion-evidence run products + local sample mirror (W5; not source -
# dev samples come from R2/MinIO per ADR-0007). The SAMPLE evidence JSON regenerates per run so it
# stays ignored; the durable FULL-data H2 champion evidence (*_experiment_results_full.json, produced
# rarely on the box and read by promote-model) IS versioned as the audit record. Ignore the dir
# CONTENTS (not the dir) so the negation can re-include the full-data file.
training/data/eval/promotion/*
!training/data/eval/promotion/*_experiment_results_full*.json
# The carry-promotion NON-INFERIORITY gate row ([166]/ADR-0012) is ALSO a durable audit record read
# by promote-model, but it deliberately does NOT match the *_experiment_results_full*.json glob above:
# that same glob is what backend/build.gradle.kts bundles into the public /accuracy scorecard, where
# this raw-softmax v2-vs-v1 row (model_name=battedball_outcome) would collide with the served
# champion's calibrated row. So it gets its own explicit negation here instead of the glob.
!training/data/eval/promotion/battedball_outcome_carry_promotion_gate.json
# ...but keep the exploratory temperature calibrations box-local (superseded
# side-quests). The versioned record is isotonic (the standing best) +
# per_park_isotonic (the gate-gaming negative); the *_temperature* runs were
# negative side-quests and just trip --allow-dirty on the box otherwise. This
# pattern follows the negation so it re-ignores them.
training/data/eval/promotion/*_temperature*.json
training/data/samples/

# Local fold-export caches: the v2-clean parquet folds + their manifest/mappings json (~730MB each)
# produced on the box / fetched from R2 for off-box training (production.py --folds-dir). Data
# artifacts, never committed (CLAUDE.md) - the only thing forcing the box deploy to pass
# --allow-dirty. Layout differs by machine: training/data/fold_export/ (box), training/data/folds/
# and data/fold_export/ (Mac fetch) - ignore all of them.
training/data/fold_export/
training/data/folds/
/data/

# Model artifacts NEVER go in git (CLAUDE.md hard never-rule)
training/artifacts/**
!training/artifacts/.gitkeep

# --- Frontend / Node ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/

# --- Infra runtime state ---
infra/clickhouse-data/
infra/grafana-data/
infra/prometheus-data/

# --- WS4: Alertmanager Discord webhook secret (the .example is committed; the real URL is not) ---
infra/alertmanager/secrets/discord_url

# --- M5: Prometheus scrape credentials for the ADMIN-gated /actuator/prometheus (.example committed) ---
# Ignore every real secret in the dir (metrics_pw, the stale metrics_authz, anything future) but keep
# the committed *.example templates.
infra/prometheus/secrets/*
!infra/prometheus/secrets/*.example

# --- M2: real box configs reconstructed from the committed .example templates (never committed) ---
infra/default-bullpen.env
infra/cloudflared/config.yml
infra/cloudflared/*.json

# --- Local snapshots (created by the destructive-CH hook gate on dev boxes) ---
snapshots/

# --- Local logs ---
*.log
logs/

# --- Local run products (D4: kept biting us as accidental commits) ---
# New deploy records written by deploy.sh during local/test runs, and nohup output.
# Already-tracked deploy records under docs/deploys/ stay tracked; this only stops NEW ones
# from being swept in by `git add .`.
docs/deploys/*.md
!docs/deploys/.gitkeep
nohup.out

# Schemathesis run cache (contract fuzzing)
.schemathesis/
