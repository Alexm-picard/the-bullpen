# OS / editor
.DS_Store
.idea/
.vscode/
*.iml
*.swp

# Tool scratch — Playwright MCP console logs + QA screenshots (local only)
.playwright-mcp/

# Secrets — never commit
.env
.env.*
!.env.example

# --- Java / Gradle ---
backend/.gradle/
backend/build/
backend/out/
backend/bin/
backend/data/                  # local SQLite registry; the schema lives in src/main/resources/db/migration
backend/HELP.md

# --- Python / uv ---
training/.venv/
training/.python-version
__pycache__/
*.pyc
training/.pytest_cache/
training/.ruff_cache/
training/.coverage
training/htmlcov/
training/build/
training/dist/
training/*.egg-info/

# Promotion-evidence run products + local sample mirror (W5; not source -
# dev samples come from R2/MinIO per ADR-0007, evidence JSON regenerates per run)
training/data/eval/promotion/
training/data/samples/

# Model artifacts NEVER go in git (CLAUDE.md hard never-rule)
training/artifacts/**
!training/artifacts/.gitkeep

# --- Frontend / Node ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/

# --- Infra runtime state ---
infra/clickhouse-data/
infra/grafana-data/
infra/prometheus-data/

# --- Local snapshots (created by the destructive-CH hook gate on dev boxes) ---
snapshots/

# --- Local logs ---
*.log
logs/

# --- Local run products (D4: kept biting us as accidental commits) ---
# New deploy records written by deploy.sh during local/test runs, and nohup output.
# Already-tracked deploy records under docs/deploys/ stay tracked; this only stops NEW ones
# from being swept in by `git add .`.
docs/deploys/*.md
!docs/deploys/.gitkeep
nohup.out
