{
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(./deploy.sh)",
      "Bash(uv *)",
      "Bash(uv run *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(java *)",
      "Bash(sqlite3 *)",
      "Bash(clickhouse-client *)",
      "Bash(clickhouse-backup *)",
      "Bash(curl -fsS *)",
      "Bash(systemctl status *)",
      "Bash(journalctl *)",
      "Bash(docker compose *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(systemctl stop clickhouse*)",
      "Bash(docker compose down*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-java.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-python.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-ts.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-retro-decisions.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/live-game-reminder.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-destructive-ch.sh" }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  }
}
