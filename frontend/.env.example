# Frontend build/runtime config (Vite). Copy to .env.local for local dev (optional - dev defaults
# to http://localhost:8080) or set these in the Vercel project for production.

# Base URL of The Bullpen API. REQUIRED for a production build: the app fails fast at load if this
# is unset in a prod build, rather than silently falling back to http://localhost:8080 (which would
# make every API call quietly fail). Dev/test default to http://localhost:8080 when unset.
VITE_API_BASE=https://api.thebullpen.net

# Optional: GlitchTip/Sentry DSN for frontend error tracking (ADR-0008). Blank/unset disables it
# (Vite tree-shakes @sentry/react out of the bundle).
# VITE_SENTRY_DSN=
